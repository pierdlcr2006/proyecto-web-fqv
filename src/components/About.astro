---
const milestones = [
	{ year: '2009', title: 'Inicio de operaciones', desc: 'Iniciamos ejecutando servicios técnicos y obras menores para clientes industriales.' },
	{ year: '2014', title: 'Expansión operativa', desc: 'Integramos nuevas especialidades: montaje, mantenimiento y soporte en campo.' },
	{ year: '2019', title: 'Cobertura nacional', desc: 'Consolidamos proyectos en costa, sierra y selva para minería, energía e infraestructura.' },
	{ year: 'Hoy', title: 'Ejecución integral', desc: 'Operamos con enfoque 360°: planificación, seguridad, ejecución y entrega controlada.' },
];

const pillars = [
	{
		title: 'Planificación Técnica',
		desc: 'Antes de iniciar, definimos alcance, riesgos, recursos y ruta crítica para proteger plazos y presupuesto.',
	},
	{
		title: 'Seguridad Operativa',
		desc: 'Aplicamos protocolos SST en todas las etapas: inducción, permisos, supervisión y verificación en campo.',
	},
	{
		title: 'Calidad y Control',
		desc: 'Cada hito se valida con control interno y reportes de avance para garantizar resultados consistentes.',
	},
];

const values = [
	{
		title: 'Misión',
		text: 'Entregar soluciones técnicas en construcción y servicios industriales con calidad, seguridad y cumplimiento en cada proyecto.',
	},
	{
		title: 'Visión',
		text: 'Ser una empresa referente a nivel nacional por confiabilidad operativa, mejora continua e innovación aplicada.',
	},
	{
		title: 'Valores',
		text: 'Integridad, disciplina, compromiso, trabajo en equipo y respeto por las personas, el cliente y el entorno.',
	},
];

const checks = [
	'Equipo técnico multidisciplinario con experiencia en campo.',
	'Protocolos de seguridad alineados al tipo de operación.',
	'Control de avances y trazabilidad durante toda la ejecución.',
	'Respuesta ágil para proyectos programados y urgentes.',
];
---

<section class="py-20 px-6 bg-white">
	<div class="max-w-7xl mx-auto">
		<div class="grid lg:grid-cols-[1fr_1.1fr] gap-14 items-center">
			<div class="gs-fade-left grid grid-cols-2 gap-4">
				<div class="col-span-2 rounded-2xl overflow-hidden h-72 md:h-80">
					<img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1200&q=80" alt="Equipo técnico en obra" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div class="rounded-2xl overflow-hidden h-44 md:h-52">
					<img src="https://images.unsplash.com/photo-1581092580497-e0d23cbdf1dc?auto=format&fit=crop&w=900&q=80" alt="Supervisión técnica" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div class="rounded-2xl bg-primary text-white p-6 flex flex-col justify-center">
					<span class="text-4xl font-black text-secondary leading-none mb-2">15+</span>
					<p class="text-sm text-white/80">Años acompañando proyectos de alto impacto en Perú.</p>
				</div>
			</div>

			<div class="gs-fade-right">
				<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Quiénes Somos</span>
				<h2 class="font-display text-4xl md:text-5xl text-primary leading-none tracking-wide mb-4">Una empresa técnica, cercana y orientada a resultados</h2>
				<p class="text-muted text-lg leading-relaxed mb-4">
					<strong class="text-primary">FQV Contratistas y Servicios Generales SAC</strong> desarrolla proyectos para construcción,
					industria, minería e infraestructura con una metodología centrada en seguridad y cumplimiento.
				</p>
				<p class="text-muted leading-relaxed mb-6">
					Nos involucramos desde la etapa de evaluación para diseñar una ejecución realista, controlada y trazable,
					adaptada a la operación de cada cliente.
				</p>
				<div class="grid sm:grid-cols-3 gap-3 mb-7">
					<div class="bg-surface border border-gray-200 rounded-xl px-4 py-3 text-center">
						<span class="block text-2xl font-black text-secondary">500+</span>
						<span class="text-xs uppercase tracking-wide text-muted">Proyectos</span>
					</div>
					<div class="bg-surface border border-gray-200 rounded-xl px-4 py-3 text-center">
						<span class="block text-2xl font-black text-secondary">98%</span>
						<span class="text-xs uppercase tracking-wide text-muted">Satisfacción</span>
					</div>
					<div class="bg-surface border border-gray-200 rounded-xl px-4 py-3 text-center">
						<span class="block text-2xl font-black text-secondary">24/7</span>
						<span class="text-xs uppercase tracking-wide text-muted">Soporte</span>
					</div>
				</div>
				<div class="flex flex-wrap gap-3">
					<a href="/contacto" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md font-semibold text-sm bg-primary text-white hover:bg-primary-light transition-colors">
						Hablar con un asesor
						<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
					<a href="/proyectos" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md font-semibold text-sm border-2 border-primary/20 text-primary hover:bg-primary/5 transition-all duration-300">
						Ver proyectos
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="py-20 px-6 bg-surface">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-12 gs-fade-up">
			<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Nuestra Trayectoria</span>
			<h2 class="font-display text-4xl md:text-5xl text-primary leading-none tracking-wide mb-4">Crecimiento con enfoque operativo</h2>
		</div>
		<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
			{milestones.map((item) => (
				<article class="gs-fade-up bg-white border border-gray-200 rounded-2xl p-6">
					<span class="inline-flex items-center justify-center text-xs font-black px-3 py-1 rounded-full bg-primary text-white mb-4">{item.year}</span>
					<h3 class="text-lg font-bold text-primary mb-2">{item.title}</h3>
					<p class="text-sm text-muted leading-relaxed">{item.desc}</p>
				</article>
			))}
		</div>
	</div>
</section>

<section class="py-20 px-6 bg-white">
	<div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-14 items-start">
		<div class="gs-fade-left">
			<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Cómo Trabajamos</span>
			<h2 class="font-display text-4xl md:text-5xl text-primary leading-none tracking-wide mb-4">Metodología orientada a control</h2>
			<p class="text-muted text-lg leading-relaxed mb-7">Nuestro estándar operativo combina planificación, seguridad y calidad para reducir riesgos y asegurar continuidad en campo.</p>
			<div class="space-y-4">
				{pillars.map((pillar, index) => (
					<div class="group bg-surface border border-gray-200 rounded-xl p-5 hover:border-secondary/35 transition-colors">
						<div class="flex items-start gap-4">
							<span class="inline-flex w-8 h-8 shrink-0 items-center justify-center rounded-full bg-secondary text-primary text-xs font-black">0{index + 1}</span>
							<div>
								<h3 class="text-lg font-bold text-primary mb-1">{pillar.title}</h3>
								<p class="text-sm text-muted leading-relaxed">{pillar.desc}</p>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>

		<div class="gs-fade-right">
			<div class="rounded-2xl overflow-hidden h-64 md:h-72 mb-5">
				<img src="https://images.unsplash.com/photo-1581091870627-3a5f14f6f9f4?auto=format&fit=crop&w=1200&q=80" alt="Reunión técnica de planificación" class="w-full h-full object-cover" loading="lazy" />
			</div>
			<div class="bg-primary text-white rounded-2xl p-7">
				<h3 class="font-display text-3xl leading-none tracking-wide mb-4">Compromiso en cada etapa</h3>
				<ul class="space-y-3">
					{checks.map((item) => (
						<li class="flex items-start gap-3 text-sm text-white/90">
							<span class="mt-[2px] w-6 h-6 rounded-full bg-secondary text-primary flex items-center justify-center text-xs font-black">✓</span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</div>
</section>

<section class="py-20 px-6 bg-surface">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-12 gs-fade-up">
			<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Nuestra Cultura</span>
			<h2 class="font-display text-4xl md:text-5xl text-primary leading-none tracking-wide">Misión, Visión y Valores</h2>
		</div>
		<div class="grid md:grid-cols-3 gap-6">
			{values.map((item) => (
				<div class="gs-fade-up bg-white border border-gray-200 rounded-2xl p-7">
					<h3 class="text-2xl font-display text-primary leading-none tracking-wide mb-3">{item.title}</h3>
					<p class="text-sm text-muted leading-relaxed">{item.text}</p>
				</div>
			))}
		</div>
	</div>
</section>

<section class="relative py-18 px-6 bg-gradient-to-br from-primary to-dark overflow-hidden">
	<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
		<div class="gs-fade-left text-center md:text-left">
			<h3 class="font-display text-3xl md:text-4xl text-white leading-none tracking-wide mb-3">¿Quieres trabajar con un equipo confiable?</h3>
			<p class="text-white/75 max-w-[620px]">Cuéntanos tu proyecto y armamos una propuesta técnica con alcance, tiempos y plan de ejecución.</p>
		</div>
		<div class="gs-fade-right flex flex-col sm:flex-row gap-4">
			<a href="/contacto" class="inline-flex items-center justify-center px-7 py-3.5 rounded-md font-semibold bg-secondary text-primary hover:bg-secondary-light transition-all duration-300">Solicitar cotización</a>
			<a href="/servicios" class="inline-flex items-center justify-center px-7 py-3.5 rounded-md font-semibold border-2 border-white text-white hover:bg-white hover:text-primary transition-all duration-300">Ver servicios</a>
		</div>
	</div>
</section>
