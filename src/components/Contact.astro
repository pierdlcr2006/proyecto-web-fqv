---
---

<section class="py-20 px-6 bg-white">
	<div class="max-w-7xl mx-auto">
		<div class="grid lg:grid-cols-5 gap-16">
			<!-- FORM -->
			<div class="lg:col-span-3 gs-fade-left">
				<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Escríbenos</span>
				<h2 class="font-display text-3xl md:text-4xl text-primary mb-3">Envíanos un Mensaje</h2>
				<p class="text-muted mb-8">Completa el formulario y nos pondremos en contacto a la brevedad.</p>

				<form class="space-y-5" id="contact-form">
					<div class="grid sm:grid-cols-2 gap-5">
						<div>
							<label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Nombre completo</label>
							<input type="text" id="name" name="name" required placeholder="Tu nombre"
								class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-surface text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
						</div>
						<div>
							<label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Teléfono</label>
							<input type="tel" id="phone" name="phone" placeholder="+51 999 999 999"
								class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-surface text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
						</div>
					</div>
					<div>
						<label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Correo electrónico</label>
						<input type="email" id="email" name="email" required placeholder="tu@email.com"
							class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-surface text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
					</div>
					<div>
						<label for="service" class="block text-sm font-semibold text-gray-700 mb-1.5">Servicio de interés</label>
						<select id="service" name="service"
							class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-surface text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
							<option value="">Selecciona un servicio</option>
							<option>Construcción Civil</option>
							<option>Mantenimiento Industrial</option>
							<option>Instalaciones Eléctricas</option>
							<option>Acabados y Remodelaciones</option>
							<option>Movimiento de Tierras</option>
							<option>Seguridad y Señalización</option>
						</select>
					</div>
					<div>
						<label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Mensaje</label>
						<textarea id="message" name="message" required rows="5" placeholder="Cuéntanos sobre tu proyecto..."
							class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-surface text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition resize-y"></textarea>
					</div>
					<button type="submit"
						class="inline-flex items-center gap-2 px-8 py-4 rounded-md font-semibold text-base bg-primary text-white hover:bg-primary-light hover:-translate-y-0.5 hover:shadow-lg transition-all duration-300 cursor-pointer">
						Enviar Mensaje
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
					</button>
					<a href="https://wa.me/51999999999" target="_blank" rel="noreferrer"
						class="inline-flex items-center gap-2 px-8 py-4 rounded-md font-semibold text-base border-2 border-green-600 text-green-700 hover:bg-green-50 transition-all duration-300">
						WhatsApp directo
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.52 3.48A11.85 11.85 0 0 0 12.06 0C5.5 0 .15 5.34.15 11.9c0 2.1.55 4.16 1.59 5.98L0 24l6.3-1.65a11.9 11.9 0 0 0 5.75 1.47h.01c6.56 0 11.9-5.34 11.9-11.9 0-3.18-1.24-6.17-3.44-8.44Zm-8.46 18.3h-.01a9.9 9.9 0 0 1-5.03-1.37l-.36-.21-3.74.98 1-3.65-.24-.38a9.88 9.88 0 0 1-1.51-5.25C2.15 6.44 6.6 2 12.06 2c2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.46-4.45 9.9-9.88 9.9Zm5.43-7.42c-.3-.15-1.77-.87-2.05-.96-.27-.1-.47-.15-.67.15s-.76.96-.93 1.16c-.17.2-.35.22-.64.08-.3-.15-1.25-.46-2.38-1.46-.88-.79-1.48-1.77-1.65-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.67-1.62-.92-2.22-.24-.58-.48-.5-.67-.5h-.57c-.2 0-.52.08-.8.38-.27.3-1.04 1.01-1.04 2.46s1.07 2.86 1.22 3.06c.15.2 2.1 3.2 5.1 4.5.71.31 1.27.5 1.7.64.72.23 1.37.2 1.89.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35Z"/></svg>
					</a>
				</form>
			</div>

			<!-- INFO -->
			<div class="lg:col-span-2 gs-fade-right flex flex-col gap-6">
				<div>
					<span class="inline-block text-xs font-bold text-secondary uppercase tracking-widest bg-secondary/10 px-4 py-1.5 rounded-full mb-3">Información</span>
					<h3 class="font-display text-2xl text-primary mb-3">Datos de Contacto</h3>
				</div>

				{[
					{ icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>', label: 'Dirección', text: 'Av. Principal 123, Lima, Perú' },
					{ icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>', label: 'Teléfono', text: '+51 999 999 999\nWhatsApp: +51 999 999 999' },
					{ icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>', label: 'Email', text: 'info@fqvcontratistas.pe' },
					{ icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>', label: 'Horario', text: 'Lun - Vie: 8:00 AM - 6:00 PM\nSáb: 8:00 AM - 1:00 PM' },
				].map((item) => (
					<div class="flex items-start gap-4 p-5 bg-surface rounded-2xl border border-gray-100">
						<div class="w-12 h-12 bg-gradient-to-br from-primary/5 to-primary-light/10 rounded-xl flex items-center justify-center shrink-0">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={item.icon} /></svg>
						</div>
						<div>
							<span class="block text-xs font-bold text-secondary uppercase tracking-wide mb-0.5">{item.label}</span>
							<p class="text-sm text-gray-700 whitespace-pre-line leading-relaxed">{item.text}</p>
						</div>
					</div>
				))}

				<!-- MAP PLACEHOLDER -->
				<div class="aspect-video rounded-2xl overflow-hidden bg-gray-200 border border-gray-200 flex items-center justify-center text-muted text-sm">
					<span>📍 Mapa (Google Maps embed aquí)</span>
				</div>
			</div>
		</div>
	</div>
</section>
